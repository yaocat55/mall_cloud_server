<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.net.mall.message.mapper.CommonNotifyMapper">

    <resultMap type="cn.net.mall.message.entity.CommonNotifyEntity" id="CommonNotifyResult">
        <result property="id" column="id"/>
        <result property="type" column="type"/>
        <result property="title" column="title"/>
        <result property="content" column="content"/>
        <result property="linkUrl" column="link_url"/>
        <result property="readStatus" column="read_status"/>
        <result property="createUserId" column="create_user_id"/>
        <result property="createUserName" column="create_user_name"/>
        <result property="createTime" column="create_time"/>
        <result property="updateUserId" column="update_user_id"/>
        <result property="updateUserName" column="update_user_name"/>
        <result property="updateTime" column="update_time"/>
        <result property="isDel" column="is_del"/>
        <result property="toUserId" column="to_user_id"/>
        <result property="isPush" column="is_push"/>
    </resultMap>

    <sql id="selectCommonNotifyColumn">
         id,
         type,
         title,
         content,
         link_url,
         read_status,
         to_user_id,
         is_push,
         create_user_id,
         create_user_name,
         create_time,
         update_user_id,
         update_user_name,
         update_time,
         is_del
    </sql>

    <sql id="queryWhere">
        <where>

            <if test="id != null ">
                AND id = #{id}
            </if>

            <if test="type != null ">
                AND type = #{type}
            </if>

            <if test="title != null  and title != ''">
                AND title = #{title}
            </if>

            <if test="content != null  and content != ''">
                AND content = #{content}
            </if>

            <if test="linkUrl != null  and linkUrl != ''">
                AND link_url = #{linkUrl}
            </if>

            <if test="readStatus != null ">
                AND read_status = #{readStatus}
            </if>

            <if test="toUserId != null ">
                AND to_user_id = #{toUserId}
            </if>

            <if test="isPush != null ">
                AND is_push = #{isPush}
            </if>

            <if test="createUserId != null ">
                AND create_user_id = #{createUserId}
            </if>

            <if test="createUserName != null  and createUserName != ''">
                AND create_user_name = #{createUserName}
            </if>

            <if test="createTime != null ">
                AND create_time = #{createTime}
            </if>

            <if test="updateUserId != null ">
                AND update_user_id = #{updateUserId}
            </if>

            <if test="updateUserName != null  and updateUserName != ''">
                AND update_user_name = #{updateUserName}
            </if>

            <if test="updateTime != null ">
                AND update_time = #{updateTime}
            </if>

            <if test="isDel != null ">
                AND is_del = #{isDel}
            </if>
            AND is_del = 0
        </where>
    </sql>

    <select id="findById" parameterType="Long"
            resultMap="CommonNotifyResult">
        SELECT
        <include refid="selectCommonNotifyColumn"/>
        FROM common_notify
        WHERE id = #{id}
    </select>

    <select id="searchByCondition"
            parameterType="cn.net.mall.message.entity.CommonNotifyConditionEntity"
            resultMap="CommonNotifyResult">
        SELECT
        <include refid="selectCommonNotifyColumn"/>
        FROM common_notify
        <include refid="queryWhere"/>
        <include refid="cn.net.mall.message.mapper.BaseMapper.paginationSql"/>
    </select>

    <select id="searchCount"
            parameterType="cn.net.mall.message.entity.CommonNotifyConditionEntity"
            resultType="int">
        SELECT
        COUNT(*)
        FROM common_notify
        <include refid="queryWhere"/>
    </select>


    <update id="update" parameterType="cn.net.mall.message.entity.CommonNotifyEntity">
        UPDATE common_notify
        <trim prefix="SET" suffixOverrides=",">

            <if test="type != null ">
                type = #{type},
            </if>


            <if test="title != null  and title != ''">
                title = #{title},
            </if>


            <if test="content != null  and content != ''">
                content = #{content},
            </if>


            <if test="linkUrl != null  and linkUrl != ''">
                link_url = #{linkUrl},
            </if>


            <if test="readStatus != null ">
                read_status = #{readStatus},
            </if>

            <if test="isPush != null ">
                is_push = #{isPush},
            </if>

            <if test="createUserId != null ">
                create_user_id = #{createUserId},
            </if>


            <if test="createUserName != null  and createUserName != ''">
                create_user_name = #{createUserName},
            </if>


            <if test="createTime != null ">
                create_time = #{createTime},
            </if>


            <if test="updateUserId != null ">
                update_user_id = #{updateUserId},
            </if>


            <if test="updateUserName != null  and updateUserName != ''">
                update_user_name = #{updateUserName},
            </if>


            <if test="updateTime != null ">
                update_time = #{updateTime},
            </if>


            <if test="isDel != null ">
                is_del = #{isDel},
            </if>

            update_time=now(3)
        </trim>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        UPDATE common_notify
        SET is_del = 1,update_time=now(3)
        WHERE id = #{id}
    </delete>

    <insert id="insert" parameterType="cn.net.mall.message.entity.CommonNotifyEntity" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO common_notify
        <trim prefix="(" suffix=")" suffixOverrides=",">
            id,
            <if test="type != null ">
                type,
            </if>


            <if test="title != null  and title != ''">
                title,
            </if>


            <if test="content != null  and content != ''">
                content,
            </if>


            <if test="linkUrl != null  and linkUrl != ''">
                link_url,
            </if>


            <if test="readStatus != null ">
                read_status,
            </if>

            <if test="toUserId != null ">
                to_user_id,
            </if>
            <if test="isPush != null ">
                is_push,
            </if>

            create_user_id,
            create_user_name,
            create_time,

            <if test="updateUserId != null ">
                update_user_id,
            </if>


            <if test="updateUserName != null  and updateUserName != ''">
                update_user_name,
            </if>


            <if test="updateTime != null ">
                update_time,
            </if>


            <if test="isDel != null ">
                is_del,
            </if>

        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            #{GENERATE_ID},
            <if test="type != null ">
                #{type},
            </if>

            <if test="title != null  and title != ''">
                #{title},
            </if>

            <if test="content != null  and content != ''">
                #{content},
            </if>

            <if test="linkUrl != null  and linkUrl != ''">
                #{linkUrl},
            </if>

            <if test="readStatus != null ">
                #{readStatus},
            </if>

            <if test="toUserId != null ">
                #{toUserId},
            </if>
            <if test="isPush != null">
                #{isPush},
            </if>

            #{CURRENT_USER_ID},
            #{CURRENT_USER_NAME},
            now(3),

            <if test="updateUserId != null ">
                #{updateUserId},
            </if>

            <if test="updateUserName != null  and updateUserName != ''">
                #{updateUserName},
            </if>

            <if test="updateTime != null ">
                #{updateTime},
            </if>

            <if test="isDel != null ">
                #{isDel},
            </if>

        </trim>
    </insert>

</mapper>
