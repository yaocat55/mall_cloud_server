### ============================================================
### Mall Cloud — Admin 模块接口测试脚本
### 直连服务端口（不经过 Gateway / BFF）
###
### 使用方式：IDEA 打开 → 点绿色箭头逐个运行
###
### Step 1：testLogin → 获取 Token
### Step 2+：后续请求自动携带 Token
### ============================================================

@ADMIN = http://localhost:8030


### ============================================================
### Step 1：获取 Token（testLogin 跳过验证码）
### ============================================================

# @name testLogin
POST {{ADMIN}}/v1/auth/user/testLogin
Content-Type: application/json

{
  "username": "admin",
  "password": "admin123"
}


### ============================================================
### Step 2：以下请求自动携带 Token
### ============================================================

### ---------- 用户管理 ----------

# @name searchUser
POST {{ADMIN}}/v1/auth/user/searchByPage
Content-Type: application/json
Authorization: Bearer {{testLogin.response.body.token}}

{
  "page": 1,
  "pageSize": 10
}

###
GET {{ADMIN}}/v1/auth/user/findById?id=1
Authorization: Bearer {{testLogin.response.body.token}}

###
POST {{ADMIN}}/v1/auth/user/resetPwd
Content-Type: application/json
Authorization: Bearer {{testLogin.response.body.token}}

{
  "id": 1,
  "password": "newpassword123"
}


### ---------- 角色管理 ----------

###
GET {{ADMIN}}/v1/auth/role/all
Authorization: Bearer {{testLogin.response.body.token}}

###
POST {{ADMIN}}/v1/auth/role/insert
Content-Type: application/json
Authorization: Bearer {{testLogin.response.body.token}}

{
  "name": "测试角色",
  "code": "TEST_ROLE",
  "sort": 1,
  "status": 1
}

###
POST {{ADMIN}}/v1/auth/role/searchByPage
Content-Type: application/json
Authorization: Bearer {{testLogin.response.body.token}}

{
  "page": 1,
  "pageSize": 10
}


### ---------- 菜单管理 ----------

###
GET {{ADMIN}}/v1/auth/menu/getMenuTree
Authorization: Bearer {{testLogin.response.body.token}}

###
POST {{ADMIN}}/v1/auth/menu/getMenu
Content-Type: application/json
Authorization: Bearer {{testLogin.response.body.token}}

{
  "page": 1,
  "pageSize": 50
}

###
POST {{ADMIN}}/v1/auth/menu/insert
Content-Type: application/json
Authorization: Bearer {{testLogin.response.body.token}}

{
  "parentId": 0,
  "name": "测试菜单",
  "permission": "system:test:list",
  "type": 1,
  "sort": 99,
  "icon": "el-icon-setting"
}

###
POST {{ADMIN}}/v1/auth/menu/deleteByIds
Content-Type: application/json
Authorization: Bearer {{testLogin.response.body.token}}

{
  "ids": [999]
}


