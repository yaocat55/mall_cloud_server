<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.net.mall.basic.mapper.common.CommonSensitiveWordMapper">

    <resultMap type="cn.net.mall.basic.entity.common.CommonSensitiveWordEntity" id="CommonSensitiveWordResult">
        <result property="id" column="id"/>
        <result property="type" column="type"/>
        <result property="word" column="word"/>
        <result property="createUserId" column="create_user_id"/>
        <result property="createUserName" column="create_user_name"/>
        <result property="createTime" column="create_time"/>
        <result property="updateUserId" column="update_user_id"/>
        <result property="updateUserName" column="update_user_name"/>
        <result property="updateTime" column="update_time"/>
        <result property="isDel" column="is_del"/>
    </resultMap>

    <sql id="selectCommonSensitiveWordColumn">
         id,
         type,
         word,
         create_user_id,
         create_user_name,
         create_time,
         update_user_id,
         update_user_name,
         update_time,
         is_del
    </sql>

    <sql id="queryWhere">
        <where>

            <if test="id != null ">
                AND id = #{id}
            </if>

            <if test="type != null ">
                AND type = #{type}
            </if>

            <if test="word != null  and word != ''">
                AND word = #{word}
            </if>

            <if test="createUserId != null ">
                AND create_user_id = #{createUserId}
            </if>

            <if test="createUserName != null  and createUserName != ''">
                AND create_user_name = #{createUserName}
            </if>

            <if test="createTime != null ">
                AND create_time = #{createTime}
            </if>

            <if test="updateUserId != null ">
                AND update_user_id = #{updateUserId}
            </if>

            <if test="updateUserName != null  and updateUserName != ''">
                AND update_user_name = #{updateUserName}
            </if>

            <if test="updateTime != null ">
                AND update_time = #{updateTime}
            </if>

            <if test="isDel != null ">
                AND is_del = #{isDel}
            </if>
            AND is_del = 0
        </where>
    </sql>

    <select id="findById" parameterType="Long"
            resultMap="CommonSensitiveWordResult">
        SELECT
        <include refid="selectCommonSensitiveWordColumn"/>
        FROM common_sensitive_word
        WHERE id = #{id}
    </select>

    <select id="searchByCondition"
            parameterType="cn.net.mall.basic.entity.common.CommonSensitiveWordConditionEntity"
            resultMap="CommonSensitiveWordResult">
        SELECT
        <include refid="selectCommonSensitiveWordColumn"/>
        FROM common_sensitive_word
        <include refid="queryWhere"/>
        <include refid="cn.net.mall.basic.mapper.BaseMapper.paginationSql"/>
    </select>

    <select id="searchCount"
            parameterType="cn.net.mall.basic.entity.common.CommonSensitiveWordConditionEntity"
            resultType="int">
        SELECT
        COUNT(*)
        FROM common_sensitive_word
        <include refid="queryWhere"/>
    </select>


    <update id="update" parameterType="cn.net.mall.basic.entity.common.CommonSensitiveWordEntity">
        UPDATE common_sensitive_word
        <trim prefix="SET" suffixOverrides=",">

            <if test="type != null ">
                type = #{type},
            </if>


            <if test="word != null  and word != ''">
                word = #{word},
            </if>


            <if test="createUserId != null ">
                create_user_id = #{createUserId},
            </if>


            <if test="createUserName != null  and createUserName != ''">
                create_user_name = #{createUserName},
            </if>


            <if test="createTime != null ">
                create_time = #{createTime},
            </if>


            <if test="updateUserId != null ">
                update_user_id = #{updateUserId},
            </if>


            <if test="updateUserName != null  and updateUserName != ''">
                update_user_name = #{updateUserName},
            </if>


            <if test="updateTime != null ">
                update_time = #{updateTime},
            </if>


            <if test="isDel != null ">
                is_del = #{isDel},
            </if>

            update_time=now(3)
        </trim>
        WHERE id = #{id}
    </update>

    <delete id="deleteByIds">
        UPDATE common_sensitive_word
        SET is_del =
        1,update_time=now(3),update_user_id=#{entity.updateUserId},update_user_name=#{entity.updateUserName}
        WHERE id IN
        <foreach collection="ids" item="id" open="(" close=")" separator=",">
            #{id}
        </foreach>
    </delete>

    <insert id="insert" parameterType="cn.net.mall.basic.entity.common.CommonSensitiveWordEntity">
        INSERT INTO common_sensitive_word
        <trim prefix="(" suffix=")" suffixOverrides=",">
            id,
            <if test="type != null ">
                type,
            </if>


            <if test="word != null  and word != ''">
                word,
            </if>

            create_user_id,
            create_user_name,
            create_time,

            <if test="updateUserId != null ">
                update_user_id,
            </if>


            <if test="updateUserName != null  and updateUserName != ''">
                update_user_name,
            </if>


            <if test="updateTime != null ">
                update_time,
            </if>


            <if test="isDel != null ">
                is_del,
            </if>

        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            #{GENERATE_ID},
            <if test="type != null ">
                #{type},
            </if>

            <if test="word != null  and word != ''">
                #{word},
            </if>

            #{CURRENT_USER_ID},
            #{CURRENT_USER_NAME},
            now(3),

            <if test="updateUserId != null ">
                #{updateUserId},
            </if>

            <if test="updateUserName != null  and updateUserName != ''">
                #{updateUserName},
            </if>

            <if test="updateTime != null ">
                #{updateTime},
            </if>

            <if test="isDel != null ">
                #{isDel},
            </if>

        </trim>
    </insert>

    <insert id="batchInsert" parameterType="cn.net.mall.basic.entity.common.CommonSensitiveWordEntity" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO common_sensitive_word
        (
        id,
        type,
        word,
        create_user_id,
        create_user_name,
        create_time,
        is_del
        )
        VALUES
        <foreach collection="list" item="item" separator=",">
            (
            #{item.id},
            #{item.type},
            #{item.word},
            #{CURRENT_USER_ID},
            #{CURRENT_USER_NAME},
            now(3),
            0
            )
        </foreach>
    </insert>

    <select id="findByIds" parameterType="Long"
            resultMap="CommonSensitiveWordResult">
        SELECT
        <include refid="selectCommonSensitiveWordColumn"/>
        FROM common_sensitive_word
        WHERE id IN
        <foreach collection="ids" item="id" open="(" close=")" separator=",">
            #{id}
        </foreach>
    </select>

</mapper>
