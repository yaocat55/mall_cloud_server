<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.net.mall.basic.mapper.common.CommonSmsRecordMapper">

    <resultMap type="cn.net.mall.basic.entity.common.CommonSmsRecordEntity" id="CommonSmsRecordResult">
        <result property="id"    column="id" />
        <result property="phone"    column="phone" />
        <result property="smsCode"    column="sms_code" />
        <result property="expireSecond"    column="expire_second" />
        <result property="sendTime"    column="send_time" />
        <result property="type"    column="type" />
        <result property="createUserId"    column="create_user_id" />
        <result property="createUserName"    column="create_user_name" />
        <result property="createTime"    column="create_time" />
        <result property="updateUserId"    column="update_user_id" />
        <result property="updateUserName"    column="update_user_name" />
        <result property="updateTime"    column="update_time" />
        <result property="isDel"    column="is_del" />
    </resultMap>


    <sql id="paginationSql">
        LIMIT #{pageBegin} , #{pageSize}
    </sql>

	<sql id="selectCommonSmsRecordColumn">
         id,
         phone,
         sms_code,
         expire_second,
         send_time,
         create_user_id,
         create_user_name,
         create_time,
         update_user_id,
         update_user_name,
         update_time,
         is_del
    </sql>

    <sql id="queryWhere">
        <where>
            <if test="idList != null and idList.size()>0">
                AND id IN
                <foreach collection="idList" item="id" open="(" close=")" separator=",">
                    #{id}
                </foreach>
            </if>
            <if test="createBeginTime != null and createBeginTime !=''">
                AND create_time >= #{createBeginTime}
            </if>

            <if test="createEndTime != null and createEndTime !=''">
                AND create_time <![CDATA[<]]> #{createEndTime}
            </if>
            <if test="id != null ">
               AND id = #{id}
            </if>
            <if test="phone != null  and phone != ''">
               AND phone = #{phone}
            </if>
            <if test="smsCode != null  and smsCode != ''">
               AND sms_code = #{smsCode}
            </if>
            <if test="expireSecond != null ">
               AND expire_second = #{expireSecond}
            </if>
            <if test="sendTime != null ">
               AND send_time = #{sendTime}
            </if>
            <if test="createUserId != null ">
               AND create_user_id = #{createUserId}
            </if>
            <if test="createUserName != null  and createUserName != ''">
               AND create_user_name = #{createUserName}
            </if>
            <if test="updateUserId != null ">
               AND update_user_id = #{updateUserId}
            </if>
            <if test="updateUserName != null  and updateUserName != ''">
               AND update_user_name = #{updateUserName}
            </if>
            <if test="isDel != null ">
               AND is_del = #{isDel}
            </if>
              AND is_del = 0
        </where>
    </sql>

    <select id="findById" parameterType="Long"
            resultMap="CommonSmsRecordResult">
        SELECT
        <include refid="selectCommonSmsRecordColumn"/>
        FROM common_sms_record
        WHERE id = #{id}
    </select>

    <select id="searchByCondition"
            parameterType="cn.net.mall.basic.entity.common.CommonSmsRecordConditionEntity"
            resultMap="CommonSmsRecordResult">
        SELECT
        <include refid="selectCommonSmsRecordColumn"/>
        FROM common_sms_record
        <include refid="queryWhere"/>
        <include refid="cn.net.mall.basic.mapper.BaseMapper.paginationSql"/>
    </select>

    <select id="searchCount"
            parameterType="cn.net.mall.basic.entity.common.CommonSmsRecordConditionEntity"
            resultType="int">
        SELECT
        COUNT(*)
        FROM common_sms_record
        <include refid="queryWhere"/>
    </select>


    <update id="update" parameterType="cn.net.mall.basic.entity.common.CommonSmsRecordEntity">
        UPDATE common_sms_record
        <trim prefix="SET" suffixOverrides=",">
            <if test="phone != null  and phone != ''">
                phone = #{phone},
            </if>
            <if test="smsCode != null  and smsCode != ''">
                sms_code = #{smsCode},
            </if>
            <if test="expireSecond != null ">
                expire_second = #{expireSecond},
            </if>
            <if test="sendTime != null ">
                send_time = #{sendTime},
            </if>
            <if test="createUserId != null ">
                create_user_id = #{createUserId},
            </if>
            <if test="createUserName != null  and createUserName != ''">
                create_user_name = #{createUserName},
            </if>
            <if test="createTime != null ">
                create_time = #{createTime},
            </if>
            <if test="updateUserId != null ">
                update_user_id = #{updateUserId},
            </if>
            <if test="updateUserName != null  and updateUserName != ''">
                update_user_name = #{updateUserName},
            </if>
            <if test="updateTime != null ">
                update_time = #{updateTime},
            </if>
            <if test="isDel != null ">
                is_del = #{isDel},
            </if>
            update_time=now(3)
        </trim>
        WHERE id = #{id}
    </update>

    <delete id="deleteByIds">
        UPDATE common_sms_record
        SET is_del = 1,update_time=now(3),update_user_id=#{entity.updateUserId},update_user_name=#{entity.updateUserName}
        WHERE id IN
        <foreach collection="ids" item="id" open="(" close=")" separator=",">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteByPhoneAndType">
        UPDATE common_sms_record
        SET is_del = 1,update_time=now(3)
        WHERE phone = #{phone} AND `type` = #{type} AND is_del=0
    </delete>

    <insert id="insert" parameterType="cn.net.mall.basic.entity.common.CommonSmsRecordEntity">
        INSERT INTO common_sms_record
        <trim prefix="(" suffix=")" suffixOverrides=",">
       id,
        <if test="phone != null  and phone != ''">
           phone,
        </if>
        <if test="smsCode != null  and smsCode != ''">
           sms_code,
        </if>
        <if test="expireSecond != null ">
           expire_second,
        </if>
        <if test="sendTime != null ">
           send_time,
        </if>
        create_user_id,
        create_user_name,
        create_time,
        <if test="updateUserId != null ">
           update_user_id,
        </if>
        <if test="updateUserName != null  and updateUserName != ''">
           update_user_name,
        </if>
        <if test="updateTime != null ">
           update_time,
        </if>
        <if test="isDel != null ">
           is_del,
        </if>
        <if test="type != null ">
            type,
        </if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
          #{GENERATE_ID},
          <if test="phone != null  and phone != ''">
             #{phone},
          </if>
          <if test="smsCode != null  and smsCode != ''">
             #{smsCode},
          </if>
          <if test="expireSecond != null ">
             #{expireSecond},
          </if>
          <if test="sendTime != null ">
             #{sendTime},
          </if>
          #{createUserId},
          #{createUserName},
          now(3),
           <if test="updateUserId != null ">
             #{updateUserId},
          </if>
          <if test="updateUserName != null  and updateUserName != ''">
             #{updateUserName},
          </if>
          <if test="updateTime != null ">
             #{updateTime},
          </if>
          <if test="isDel != null ">
             #{isDel},
          </if>
          <if test="type != null ">
            #{type},
         </if>
        </trim>
    </insert>

    <select id="findByIds" parameterType="Long"
            resultMap="CommonSmsRecordResult">
        SELECT
          <include refid="selectCommonSmsRecordColumn"/>
        FROM common_sms_record
        WHERE id IN
        <foreach collection="ids" item="id" open="(" close=")" separator=",">
            #{id}
        </foreach>
    </select>

    <select id="findSmsRecord" resultMap="CommonSmsRecordResult">
        SELECT
        <include refid="selectCommonSmsRecordColumn"/>
        FROM common_sms_record
        WHERE phone = #{phone} AND type = #{type} AND is_del = 0
        ORDER BY send_time DESC
        LIMIT 1
    </select>
</mapper>
