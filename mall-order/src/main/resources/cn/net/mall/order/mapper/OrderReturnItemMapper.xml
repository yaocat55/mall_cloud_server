<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.net.mall.order.mapper.OrderReturnItemMapper">

    <resultMap type="cn.net.mall.order.entity.OrderReturnItemEntity" id="OrderReturnItemResult">
        <result property="id" column="id"/>
        <result property="orderId" column="order_id"/>
        <result property="orderItemId" column="order_item_id"/>
        <result property="returnApplyId" column="return_apply_id"/>
        <result property="productId" column="product_id"/>
        <result property="productName" column="product_name"/>
        <result property="productModel" column="product_model"/>
        <result property="productPrice" column="product_price"/>
        <result property="quantity" column="quantity"/>
        <result property="amount" column="amount"/>
        <result property="createUserId" column="create_user_id"/>
        <result property="createUserName" column="create_user_name"/>
        <result property="createTime" column="create_time"/>
        <result property="updateUserId" column="update_user_id"/>
        <result property="updateUserName" column="update_user_name"/>
        <result property="updateTime" column="update_time"/>
        <result property="isDel" column="is_del"/>
    </resultMap>

    <sql id="selectOrderReturnItemColumn">
        id,
        order_id,
        order_item_id,
        return_apply_id,
        product_id,
        product_name,
        product_model,
        product_price,
        quantity,
        amount,
        create_user_id,
        create_user_name,
        create_time,
        update_user_id,
        update_user_name,
        update_time,
        is_del
    </sql>

    <sql id="queryWhere">
        <where>
            <if test="orderId != null ">
                AND order_id = #{orderId}
            </if>
            <if test="returnApplyId != null ">
                AND return_apply_id = #{returnApplyId}
            </if>
            <if test="orderItemId != null ">
                AND order_item_id = #{orderItemId}
            </if>
        </where>
    </sql>

    <select id="searchCount" parameterType="cn.net.mall.order.entity.OrderReturnItemConditionEntity" resultType="int">
        SELECT COUNT(1)
        FROM t_order_return_item
        <include refid="queryWhere"/>
    </select>

    <select id="searchByCondition" parameterType="cn.net.mall.order.entity.OrderReturnItemConditionEntity"
            resultMap="OrderReturnItemResult">
        SELECT
        <include refid="selectOrderReturnItemColumn"/>
        FROM t_order_return_item
        <include refid="queryWhere"/>
        <include refid="cn.net.mall.mapper.BaseMapper.paginationSql"/>
    </select>

    <insert id="insertBatch" parameterType="java.util.List" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_order_return_item
        (
            id,
            order_id,
            order_item_id,
            return_apply_id,
            product_id,
            product_name,
            product_model,
            product_price,
            quantity,
            amount,
            create_user_id,
            create_user_name,
            create_time,
            update_user_id,
            update_user_name,
            update_time,
            is_del
        )
        VALUES
        <foreach collection="list" item="item" separator=",">
            (
                #{item.id},
                #{item.orderId},
                #{item.orderItemId},
                #{item.returnApplyId},
                #{item.productId},
                #{item.productName},
                #{item.productModel},
                #{item.productPrice},
                #{item.quantity},
                #{item.amount},
                #{item.createUserId},
                #{item.createUserName},
                #{item.createTime},
                #{item.updateUserId},
                #{item.updateUserName},
                #{item.updateTime},
                #{item.isDel}
            )
        </foreach>
    </insert>
</mapper>
