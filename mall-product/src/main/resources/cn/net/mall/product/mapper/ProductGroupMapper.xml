<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.net.mall.product.mapper.ProductGroupMapper">

    <resultMap type="cn.net.mall.product.entity.ProductGroupEntity" id="ProductGroupResult">
        <result property="id" column="id"/>
        <result property="categoryId" column="category_id"/>
        <result property="name" column="name"/>
        <result property="model" column="model"/>
        <result property="unitId" column="unit_id"/>
        <result property="hash" column="hash"/>
        <result property="createUserId" column="create_user_id"/>
        <result property="createUserName" column="create_user_name"/>
        <result property="createTime" column="create_time"/>
        <result property="updateUserId" column="update_user_id"/>
        <result property="updateUserName" column="update_user_name"/>
        <result property="updateTime" column="update_time"/>
        <result property="isDel" column="is_del"/>
    </resultMap>


    <sql id="paginationSql">
        LIMIT #{pageBegin} , #{pageSize}
    </sql>

    <sql id="selectProductGroupColumn">
         id,
         category_id,
         unit_id,
         name,
         model,
         hash,
         create_user_id,
         create_user_name,
         create_time,
         update_user_id,
         update_user_name,
         update_time,
         is_del
    </sql>

    <sql id="queryWhere">
        <where>
            <if test="productGroupEntities != null and productGroupEntities.size()>0">
                <foreach collection="productGroupEntities" item="productGroupEntity" open="(" close=")" separator="or">
                    (
                    category_id = #{productGroupEntity.categoryId}
                    AND unit_id = #{productGroupEntity.unitId}
                    AND hash = #{productGroupEntity.hash}
                    )
                </foreach>
            </if>

            <if test="idList != null and idList.size()>0">
                AND id IN
                <foreach collection="idList" item="id" open="(" close=")" separator=",">
                    #{id}
                </foreach>
            </if>
            <if test="createBeginTime != null and createBeginTime !=''">
                AND create_time >= #{createBeginTime}
            </if>

            <if test="createEndTime != null and createEndTime !=''">
                AND create_time <![CDATA[<]]> #{createEndTime}
            </if>
            <if test="id != null ">
                AND id = #{id}
            </if>
            <if test="categoryId != null ">
                AND category_id = #{categoryId}
            </if>
            <if test="unitId != null ">
                AND unit_id = #{unitId}
            </if>
            <if test="name != null ">
                AND name = #{name}
            </if>
            <if test="model != null  and model != ''">
                AND model = #{model}
            </if>
            <if test="hash != null  and hash != ''">
                AND hash = #{hash}
            </if>
            <if test="createUserId != null ">
                AND create_user_id = #{createUserId}
            </if>
            <if test="createUserName != null  and createUserName != ''">
                AND create_user_name = #{createUserName}
            </if>
            <if test="updateUserId != null ">
                AND update_user_id = #{updateUserId}
            </if>
            <if test="updateUserName != null  and updateUserName != ''">
                AND update_user_name = #{updateUserName}
            </if>
            <if test="isDel != null ">
                AND is_del = #{isDel}
            </if>
            AND is_del = 0
        </where>
    </sql>

    <select id="findById" parameterType="Long"
            resultMap="ProductGroupResult">
        SELECT
        <include refid="selectProductGroupColumn"/>
        FROM product_group
        WHERE id = #{id}
    </select>

    <select id="searchByCondition"
            parameterType="cn.net.mall.product.entity.ProductGroupConditionEntity"
            resultMap="ProductGroupResult">
        SELECT
        <include refid="selectProductGroupColumn"/>
        FROM product_group
        <include refid="queryWhere"/>
        <include refid="cn.net.mall.product.mapper.BaseMapper.paginationSql"/>
    </select>

    <select id="searchCount"
            parameterType="cn.net.mall.product.entity.ProductGroupConditionEntity"
            resultType="int">
        SELECT
        COUNT(*)
        FROM product_group
        <include refid="queryWhere"/>
    </select>


    <update id="update" parameterType="cn.net.mall.product.entity.ProductGroupEntity">
        UPDATE product_group
        <trim prefix="SET" suffixOverrides=",">

            <if test="categoryId != null ">
                category_id = #{categoryId},
            </if>

            <if test="unitId != null ">
                unit_id = #{unitId},
            </if>

            <if test="name != null ">
                name = #{name},
            </if>

            <if test="model != null  and model != ''">
                model = #{model},
            </if>

            <if test="hash != null  and hash != ''">
                hash = #{hash},
            </if>


            <if test="createUserId != null ">
                create_user_id = #{createUserId},
            </if>


            <if test="createUserName != null  and createUserName != ''">
                create_user_name = #{createUserName},
            </if>


            <if test="createTime != null ">
                create_time = #{createTime},
            </if>


            <if test="updateUserId != null ">
                update_user_id = #{updateUserId},
            </if>


            <if test="updateUserName != null  and updateUserName != ''">
                update_user_name = #{updateUserName},
            </if>


            <if test="updateTime != null ">
                update_time = #{updateTime},
            </if>


            <if test="isDel != null ">
                is_del = #{isDel},
            </if>

            update_time=now(3)
        </trim>
        WHERE id = #{id}
    </update>

    <delete id="deleteByIds">
        UPDATE product_group
        SET is_del =
        1,update_time=now(3),update_user_id=#{entity.updateUserId},update_user_name=#{entity.updateUserName},del_id=id
        WHERE id IN
        <foreach collection="ids" item="id" open="(" close=")" separator=",">
            #{id}
        </foreach>
    </delete>

    <insert id="insert" parameterType="cn.net.mall.product.entity.ProductGroupEntity">
        INSERT INTO product_group
        <trim prefix="(" suffix=")" suffixOverrides=",">
            id,
            <if test="categoryId != null ">
                category_id,
            </if>
            <if test="unitId != null ">
                unit_id,
            </if>
            <if test="name != null ">
                name,
            </if>
            <if test="model != null ">
                model,
            </if>
            <if test="hash != null  and hash != ''">
                hash,
            </if>
            create_user_id,
            create_user_name,
            create_time,
            <if test="updateUserId != null ">
                update_user_id,
            </if>
            <if test="updateUserName != null  and updateUserName != ''">
                update_user_name,
            </if>
            <if test="updateTime != null ">
                update_time,
            </if>
            <if test="isDel != null ">
                is_del,
            </if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            #{GENERATE_ID},
            <if test="categoryId != null ">
                #{categoryId},
            </if>
            <if test="unitId != null ">
                #{unitId},
            </if>
            <if test="name != null ">
                #{name},
            </if>
            <if test="model != null">
                #{model},
            </if>
            <if test="hash != null  and hash != ''">
                #{hash},
            </if>
            #{CURRENT_USER_ID},
            #{CURRENT_USER_NAME},
            now(3),
            <if test="updateUserId != null ">
                #{updateUserId},
            </if>
            <if test="updateUserName != null  and updateUserName != ''">
                #{updateUserName},
            </if>
            <if test="updateTime != null ">
                #{updateTime},
            </if>
            <if test="isDel != null ">
                #{isDel},
            </if>
        </trim>
    </insert>

    <select id="findByIds" parameterType="Long"
            resultMap="ProductGroupResult">
        SELECT
        <include refid="selectProductGroupColumn"/>
        FROM product_group
        WHERE id IN
        <foreach collection="ids" item="id" open="(" close=")" separator=",">
            #{id}
        </foreach>
    </select>

    <insert id="batchInsert" parameterType="cn.net.mall.product.entity.ProductGroupEntity" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO product_group
        (
        id,
        category_id,
        unit_id,
        name,
        model,
        hash,
        create_user_id,
        create_user_name,
        create_time,
        is_del
        )
        VALUES
        <foreach collection="list" item="item" separator=",">
            (
            #{item.id},
            #{item.categoryId},
            #{item.unitId},
            #{item.name},
            #{item.model},
            #{item.hash},
            #{CURRENT_USER_ID},
            #{CURRENT_USER_NAME},
            now(3),
            0
            )
        </foreach>
    </insert>

</mapper>
