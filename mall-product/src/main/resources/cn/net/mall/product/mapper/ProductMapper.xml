<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.net.mall.product.mapper.ProductMapper">

    <resultMap type="cn.net.mall.product.entity.ProductEntity" id="ProductResult">
        <result property="id" column="id"/>
        <result property="categoryId" column="category_id"/>
        <result property="brandId" column="brand_id"/>
        <result property="unitId" column="unit_id"/>
        <result property="productGroupId" column="product_group_id"/>
        <result property="name" column="name"/>
        <result property="model" column="model"/>
        <result property="hash" column="hash"/>
        <result property="quantity" column="quantity"/>
        <result property="remainQuantity" column="remain_quantity"/>
        <result property="price" column="price"/>
        <result property="createUserId" column="create_user_id"/>
        <result property="createUserName" column="create_user_name"/>
        <result property="createTime" column="create_time"/>
        <result property="updateUserId" column="update_user_id"/>
        <result property="updateUserName" column="update_user_name"/>
        <result property="updateTime" column="update_time"/>
        <result property="isDel" column="is_del"/>
        <result property="coverUrl" column="cover_url"/>
        <result property="saleCount" column="sale_count"/>
    </resultMap>


    <sql id="selectProductColumn">
         id,
         category_id,
         brand_id,
         unit_id,
         product_group_id,
         name,
         model,
         hash,
         quantity,
         remain_quantity,
         price,
         create_user_id,
         create_user_name,
         create_time,
         update_user_id,
         update_user_name,
         update_time,
         is_del,
         cover_url,
         sale_count
    </sql>

    <sql id="queryWhere">
        <where>
          <if test="productEntities != null and productEntities.size()>0">
              <foreach collection="productEntities" item="productEntity" open="(" close=")" separator="or">
                  (
                     product_group_id = #{productEntity.productGroupId}
                     AND brand_id = #{productEntity.brandId}
                     AND hash = #{productEntity.hash}
                  )
              </foreach>
          </if>

            <if test="id != null ">
                AND id = #{id}
            </if>

            <if test="idList != null and idList.size()>0">
                AND id IN
                <foreach collection="idList" item="id" open="(" close=")" separator=",">
                    #{id}
                </foreach>
            </if>

            <if test="productGroupIdList != null and productGroupIdList.size()>0">
                AND product_group_id IN
                <foreach collection="productGroupIdList" item="productGroupId" open="(" close=")" separator=",">
                    #{productGroupId}
                </foreach>
            </if>

            <if test="productGroupId != null ">
                AND product_group_id = #{productGroupId}
            </if>

            <if test="categoryId != null ">
                AND category_id = #{categoryId}
            </if>

            <if test="brandId != null ">
                AND brand_id = #{brandId}
            </if>

            <if test="unitId != null ">
                AND unit_id = #{unitId}
            </if>

            <if test="name != null  and name != ''">
                AND name LIKE CONCAT ('%',  #{name},'%')
            </if>

            <if test="model != null  and model != ''">
                AND model = #{model}
            </if>

            <if test="hash != null  and hash != ''">
                AND hash = #{hash}
            </if>

            <if test="quantity != null ">
                AND quantity = #{quantity}
            </if>

            <if test="price != null ">
                AND price = #{price}
            </if>

            <if test="createUserId != null ">
                AND create_user_id = #{createUserId}
            </if>

            <if test="createUserName != null  and createUserName != ''">
                AND create_user_name = #{createUserName}
            </if>

            <if test="createTime != null ">
                AND create_time = #{createTime}
            </if>

            <if test="updateUserId != null ">
                AND update_user_id = #{updateUserId}
            </if>

            <if test="updateUserName != null  and updateUserName != ''">
                AND update_user_name = #{updateUserName}
            </if>

            <if test="updateTime != null ">
                AND update_time = #{updateTime}
            </if>

            <if test="createBeginTime != null and createBeginTime !=''">
                AND create_time >= #{createBeginTime}
            </if>

            <if test="createEndTime != null and createEndTime !=''">
                AND create_time <![CDATA[<]]> #{createEndTime}
            </if>

            <if test="isDel != null ">
                AND is_del = #{isDel}
            </if>

            <if test="isDel == null">
                AND is_del = 0
            </if>
        </where>
    </sql>

    <select id="findById" parameterType="Long"
            resultMap="ProductResult">
        SELECT
        <include refid="selectProductColumn"/>
        FROM product
        WHERE id = #{id}
    </select>

    <select id="searchByCondition"
            parameterType="cn.net.mall.product.entity.ProductConditionEntity"
            resultMap="ProductResult">
        SELECT
        <include refid="selectProductColumn"/>
        FROM product
        <include refid="queryWhere"/>
        <include refid="cn.net.mall.product.mapper.BaseMapper.paginationSql"/>
    </select>

    <select id="searchCount"
            parameterType="cn.net.mall.product.entity.ProductConditionEntity"
            resultType="int">
        SELECT
        COUNT(*)
        FROM product
        <include refid="queryWhere"/>
    </select>


    <update id="update" parameterType="cn.net.mall.product.entity.ProductEntity">
        UPDATE product
        <trim prefix="SET" suffixOverrides=",">
            <if test="productGroupId != null ">
                product_group_id = #{productGroupId},
            </if>

            <if test="categoryId != null ">
                category_id = #{categoryId},
            </if>


            <if test="brandId != null ">
                brand_id = #{brandId},
            </if>


            <if test="unitId != null ">
                unit_id = #{unitId},
            </if>


            <if test="name != null  and name != ''">
                name = #{name},
            </if>


            <if test="model != null  and model != ''">
                model = #{model},
            </if>

            <if test="hash != null  and hash != ''">
                hash = #{hash},
            </if>

            <if test="quantity != null ">
                quantity = #{quantity},
            </if>


            <if test="price != null ">
                price = #{price},
            </if>

            <if test="coverUrl != null ">
                cover_url = #{coverUrl},
            </if>

            <if test="createUserId != null ">
                create_user_id = #{createUserId},
            </if>


            <if test="createUserName != null  and createUserName != ''">
                create_user_name = #{createUserName},
            </if>


            <if test="createTime != null ">
                create_time = #{createTime},
            </if>


            <if test="updateUserId != null ">
                update_user_id = #{updateUserId},
            </if>


            <if test="updateUserName != null  and updateUserName != ''">
                update_user_name = #{updateUserName},
            </if>


            <if test="updateTime != null ">
                update_time = #{updateTime},
            </if>


            <if test="isDel != null ">
                is_del = #{isDel},
            </if>

            update_time=now(3)
        </trim>
        WHERE id = #{id}
    </update>

    <delete id="deleteByIds">
        UPDATE product
        SET is_del =
        1,update_time=now(3),update_user_id=#{entity.updateUserId},update_user_name=#{entity.updateUserName},del_id=id
        WHERE id IN
        <foreach collection="ids" item="id" open="(" close=")" separator=",">
            #{id}
        </foreach>
    </delete>

    <insert id="insert" parameterType="cn.net.mall.product.entity.ProductEntity">
        INSERT INTO product
        <trim prefix="(" suffix=")" suffixOverrides=",">
            id,
            <if test="productGroupId != null ">
                product_group_id,
            </if>

            <if test="categoryId != null ">
                category_id,
            </if>

            <if test="brandId != null ">
                brand_id,
            </if>


            <if test="unitId != null ">
                unit_id,
            </if>


            <if test="name != null  and name != ''">
                name,
            </if>


            <if test="model != null  and model != ''">
                model,
            </if>

            <if test="hash != null  and hash != ''">
                hash,
            </if>

            <if test="quantity != null ">
                quantity,
            </if>

            <if test="remainQuantity != null ">
                remain_quantity,
            </if>

            <if test="price != null ">
                price,
            </if>

            <if test="coverUrl != null ">
                cover_url,
            </if>

            <if test="createUserId != null ">
                create_user_id,
            </if>


            <if test="createUserName != null  and createUserName != ''">
                create_user_name,
            </if>


            <if test="createTime != null ">
                create_time,
            </if>


            <if test="updateUserId != null ">
                update_user_id,
            </if>


            <if test="updateUserName != null  and updateUserName != ''">
                update_user_name,
            </if>


            <if test="updateTime != null ">
                update_time,
            </if>


            <if test="isDel != null ">
                is_del,
            </if>

        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            #{GENERATE_ID},
            <if test="productGroupId != null ">
                #{productGroupId},
            </if>

            <if test="categoryId != null ">
                #{categoryId},
            </if>

            <if test="brandId != null ">
                #{brandId},
            </if>

            <if test="unitId != null ">
                #{unitId},
            </if>

            <if test="name != null  and name != ''">
                #{name},
            </if>

            <if test="model != null  and model != ''">
                #{model},
            </if>

            <if test="hash != null  and hash != ''">
                #{hash},
            </if>

            <if test="quantity != null ">
                #{quantity},
            </if>

            <if test="remainQuantity != null ">
                #{remainQuantity},
            </if>

            <if test="price != null ">
                #{price},
            </if>

            <if test="coverUrl != null ">
                #{coverUrl},
            </if>

            <if test="createUserId != null ">
                #{createUserId},
            </if>

            <if test="createUserName != null  and createUserName != ''">
                #{createUserName},
            </if>

            <if test="createTime != null ">
                #{createTime},
            </if>

            <if test="updateUserId != null ">
                #{updateUserId},
            </if>

            <if test="updateUserName != null  and updateUserName != ''">
                #{updateUserName},
            </if>

            <if test="updateTime != null ">
                #{updateTime},
            </if>

            <if test="isDel != null ">
                #{isDel},
            </if>

        </trim>
    </insert>

    <insert id="batchInsert" parameterType="cn.net.mall.product.entity.ProductEntity" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO product
        (
        id,
        product_group_id,
        category_id,
        unit_id,
        brand_id,
        name,
        model,
        hash,
        quantity,
        remain_quantity,
        price,
        create_user_id,
        create_user_name,
        create_time,
        is_del,
        cover_url
        )
        VALUES
        <foreach collection="list" item="item" separator=",">
            (
            #{item.id},
            #{item.productGroupId},
            #{item.categoryId},
            #{item.unitId},
            #{item.brandId},
            #{item.name},
            #{item.model},
            #{item.hash},
            #{item.quantity},
            #{item.remainQuantity},
            #{item.price},
            #{CURRENT_USER_ID},
            #{CURRENT_USER_NAME},
            now(3),
            0,
            #{item.coverUrl}
            )
        </foreach>
    </insert>

    <select id="findByIds" parameterType="Long"
            resultMap="ProductResult">
        SELECT
        <include refid="selectProductColumn"/>
        FROM product
        WHERE id IN
        <foreach collection="ids" item="id" open="(" close=")" separator=",">
            #{id}
        </foreach>
    </select>

    <select id="getTopProducts" resultMap="ProductResult">
        SELECT
        <include refid="selectProductColumn"/>
        FROM product
        WHERE is_del = 0
        ORDER BY sale_count DESC
        LIMIT #{limit}
    </select>

    <update id="reduceStock">
        UPDATE
          product
        SET   remain_quantity = remain_quantity - #{quantity}
        WHERE id = #{id} AND remain_quantity - #{quantity} >= 0
    </update>

    <update id="addStock">
        UPDATE
          product
        SET   remain_quantity = remain_quantity + #{quantity}
        WHERE id = #{id}
    </update>
</mapper>
